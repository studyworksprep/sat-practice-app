# Example environment configuration.
#
# Copy to `.env.local` for local development and set real values.
# `.env` and `.env.local` are gitignored; this example file is not,
# so never put real secrets here — only placeholders and docs.
#
# NEXT_PUBLIC_* vars are inlined into the client bundle at build time.

# --- Desmos Graphing Calculator -------------------------------------
# Required. Browser API key for the Desmos calculator (used by the
# practice/review/practice-test pages and lesson desmos_interactive
# blocks). There is no in-code fallback: if this is unset the
# calculator will not load. Desmos browser keys are public and
# domain-restricted — generate one at https://www.desmos.com/api.
NEXT_PUBLIC_DESMOS_API_KEY=

# --- Supabase -------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Site / misc client flags ---------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Set to '1' to enable MathJax rendering.
NEXT_PUBLIC_ENABLE_MATHJAX=
# Optional Sentry browser DSN.
NEXT_PUBLIC_SENTRY_DSN=

# Server-only secrets (Supabase service role key, Stripe keys, etc.)
# are configured separately and are intentionally not listed here.
